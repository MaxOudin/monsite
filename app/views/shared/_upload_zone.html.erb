<%# Usage: render "shared/upload_zone", name: "file", accept: "image/*", multiple: false %>
<div data-controller="upload" data-upload-multiple-value="<%= local_assigns[:multiple] || false %>" class="relative">
  <div data-upload-target="dropzone" data-action="dragover->upload#dragover dragenter->upload#dragover dragleave->upload#dragleave drop->upload#drop click->upload#click"
       class="border-2 border-dashed border-gray-700 rounded-xl p-12 text-center cursor-pointer hover:border-yellow-500/50 hover:bg-gray-800/30 transition-all duration-200">
    <div data-upload-target="placeholder">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-gray-500 mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
      </svg>
      <p class="text-gray-400 mb-1">Glisser-déposer ou <span class="text-gray-900 font-medium">parcourir</span></p>
      <p class="text-sm text-gray-500">Max <%= ImageProcessor::MAX_FILE_SIZE / 1.megabyte %> Mo</p>
    </div>
    <div data-upload-target="preview" class="hidden">
      <img data-upload-target="previewImage" class="mx-auto max-h-48 rounded-lg mb-3" />
      <p data-upload-target="fileName" class="text-sm text-gray-300"></p>
      <p data-upload-target="fileSize" class="text-xs text-gray-500"></p>
    </div>
  </div>
  <input type="file" data-upload-target="input" name="<%= local_assigns[:name] || 'file' %>" accept="<%= local_assigns[:accept] || 'image/*' %>"
         class="hidden" <%= "multiple" if local_assigns[:multiple] %> />
</div>  