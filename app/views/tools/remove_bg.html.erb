<% content_for :meta_title, "Supprimer le fond d'une image - Outils" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

  <div class="mb-8">
    <%= link_to tools_path, class: "inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-xs"></i> Tous les outils
    <% end %>

    <div class="flex items-center gap-4">
      <div class="w-11 h-11 rounded-lg bg-yellow-50 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-magic text-yellow-600"></i>
      </div>
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Supprimer le fond</h1>
        <p class="text-sm text-gray-500 mt-0.5">Supprimez l'arrière-plan de votre image automatiquement</p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8">
    <%= form_with url: tools_process_remove_bg_path, method: :post, multipart: true, data: { turbo: false } do |f| %>

      <div class="mb-6">
        <%= f.label :file, "Image source", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.file_field :file,
            accept: "image/jpg,image/jpeg,image/png,image/webp",
            required: true,
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gray-900 file:text-white hover:file:bg-gray-800 transition-colors cursor-pointer" %>
        <p class="mt-1.5 text-xs text-gray-400">JPG, PNG, WebP — max <%= ImageProcessor::MAX_FILE_SIZE / 1.megabyte %> Mo. Le résultat sera un PNG avec transparence.</p>
      </div>

      <div class="mb-8 flex gap-3 p-4 bg-gray-50 rounded-lg border border-gray-200">
        <i class="fas fa-info-circle text-yellow-500 mt-0.5 flex-shrink-0"></i>
        <div class="text-xs text-gray-600">
          <p class="font-medium text-gray-800 mb-0.5">Traitement par IA</p>
          <p>Cette opération utilise un service de détection IA (<code class="bg-gray-200 px-1 rounded text-gray-700">rembg</code>). Le traitement peut prendre quelques secondes selon la complexité de l'image.</p>
        </div>
      </div>

      <%= f.submit "Supprimer le fond et télécharger",
          class: "w-full px-6 py-3 bg-gray-900 text-white text-sm font-semibold rounded-lg hover:bg-gray-800 active:bg-black transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <div class="mt-5 p-4 bg-gray-50 rounded-xl border border-gray-200">
    <h3 class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2">Conseils pour de meilleurs résultats</h3>
    <ul class="text-xs text-gray-600 space-y-1.5">
      <li><i class="fas fa-check text-yellow-500 mr-1.5"></i>Utilisez des images avec un sujet bien défini et contrasté.</li>
      <li><i class="fas fa-check text-yellow-500 mr-1.5"></i>Les fonds unis donnent les meilleurs résultats.</li>
      <li><i class="fas fa-check text-yellow-500 mr-1.5"></i>Le résultat est fourni en PNG avec canal alpha (transparence).</li>
    </ul>
    <div class="mt-3 pt-3 border-t border-gray-200">
      <p class="text-xs text-gray-500">
        Variable d'environnement requise : <code class="bg-gray-200 px-1 rounded text-gray-700">REMBG_URL</code>
        (défaut : <code class="bg-gray-200 px-1 rounded text-gray-700">http://localhost:7000</code>)
      </p>
    </div>
  </div>

</div>
