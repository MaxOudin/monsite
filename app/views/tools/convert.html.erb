<% content_for :meta_title, "Convertir une image - Outils" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

  <div class="mb-8">
    <%= link_to tools_path, class: "inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-700 transition-colors mb-6" do %>
      <i class="fas fa-arrow-left text-xs"></i> Tous les outils
    <% end %>

    <div class="flex items-center gap-4">
      <div class="w-11 h-11 rounded-lg bg-yellow-50 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-exchange-alt text-yellow-600"></i>
      </div>
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Convertir</h1>
        <p class="text-sm text-gray-500 mt-0.5">Changez le format de votre image</p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8">
    <%= form_with url: tools_process_convert_path, method: :post, multipart: true, data: { turbo: false } do |f| %>

      <div class="mb-6">
        <%= f.label :file, "Image source", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.file_field :file,
            accept: ImageProcessor::RASTER_FORMATS.map { |fmt| "image/#{fmt}" }.join(","),
            required: true,
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gray-900 file:text-white hover:file:bg-gray-800 transition-colors cursor-pointer" %>
        <p class="mt-1.5 text-xs text-gray-400">JPG, PNG, WebP, TIFF, GIF, BMP, HEIC — max <%= ImageProcessor::MAX_FILE_SIZE / 1.megabyte %> Mo</p>
      </div>

      <div class="mb-6">
        <%= f.label :format, "Format de sortie", class: "block text-sm font-medium text-gray-700 mb-3" %>
        <div class="grid grid-cols-3 sm:grid-cols-4 gap-2">
          <% [["JPG", "jpg"], ["PNG", "png"], ["WebP", "webp"], ["TIFF", "tiff"], ["GIF", "gif"], ["BMP", "bmp"], ["HEIC", "heic"]].each do |label, value| %>
            <label class="relative cursor-pointer">
              <%= f.radio_button :format, value,
                  required: true,
                  id: "format_#{value}",
                  class: "sr-only peer" %>
              <span class="flex items-center justify-center px-3 py-2.5 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 peer-checked:bg-gray-900 peer-checked:text-white peer-checked:border-gray-900 hover:border-gray-400 hover:text-gray-900 transition-colors">
                <%= label %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="mb-8" data-controller="quality-range">
        <div class="flex items-center justify-between mb-2">
          <%= f.label :quality, class: "text-sm font-medium text-gray-700" do %>
            Qualité <span class="text-gray-400 font-normal">(JPG, WebP, HEIC)</span>
          <% end %>
          <span class="text-sm font-semibold text-gray-900" data-quality-range-target="output">85</span>
        </div>
        <%= f.range_field :quality,
            value: 85, min: 10, max: 100, step: 5,
            class: "w-full h-1.5 bg-gray-200 rounded-full appearance-none cursor-pointer accent-yellow-500",
            data: { quality_range_target: "input", action: "input->quality-range#updateOutput" } %>
        <div class="flex justify-between text-xs text-gray-400 mt-1.5">
          <span>Petit fichier</span>
          <span>Haute qualité</span>
        </div>
      </div>

      <%= f.submit "Convertir et télécharger",
          class: "w-full px-6 py-3 bg-gray-900 text-white text-sm font-semibold rounded-lg hover:bg-gray-800 active:bg-black transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <div class="mt-5 p-4 bg-gray-50 rounded-xl border border-gray-200">
    <h3 class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2">Conseils par format</h3>
    <ul class="text-xs text-gray-600 space-y-1.5">
      <li><span class="font-medium text-gray-800">WebP</span> — meilleur rapport qualité/poids, idéal pour le web.</li>
      <li><span class="font-medium text-gray-800">PNG</span> — sans perte, supporte la transparence.</li>
      <li><span class="font-medium text-gray-800">JPG</span> — universel, idéal pour les photos.</li>
      <li><span class="font-medium text-gray-800">HEIC</span> — format Apple, fichiers très compacts.</li>
    </ul>
  </div>

</div>
