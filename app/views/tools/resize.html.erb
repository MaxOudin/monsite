<% content_for :meta_title, "Redimensionner une image - Outils" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

  <%= render "tools/tool_header", icon: "fa-expand-arrows-alt", title: "Redimensionner", subtitle: "Modifiez les dimensions de votre image" %>

  <div class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8">
    <%= form_with url: tools_process_resize_path, method: :post, multipart: true, data: { turbo: false } do |f| %>

      <div class="mb-6">
        <%= render "shared/upload_zone", name: "file", accept: ImageProcessor::RASTER_FORMATS.map { |fmt| "image/#{fmt}" }.join(",") %>
        <p class="mt-1.5 text-xs text-gray-400">JPG, PNG, WebP, TIFF, GIF, BMP, HEIC — max <%= ImageProcessor::MAX_FILE_SIZE / 1.megabyte %> Mo</p>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-2">
        <div>
          <%= f.label :width, "Largeur (px)", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.number_field :width,
              placeholder: "800",
              min: 1, max: 10000,
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-yellow-400 focus:border-yellow-400 transition-colors outline-none" %>
        </div>
        <div>
          <%= f.label :height, "Hauteur (px)", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.number_field :height,
              placeholder: "600",
              min: 1, max: 10000,
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-yellow-400 focus:border-yellow-400 transition-colors outline-none" %>
        </div>
      </div>
      <p class="text-xs text-gray-400 mb-6">Laissez une valeur vide pour adapter automatiquement en mode "Adapter".</p>

      <div class="mb-8">
        <%= f.label :mode, "Mode de redimensionnement", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :mode,
            [
              ["Adapter — conserve les proportions (recommandé)", "fit"],
              ["Remplir — recadre pour remplir exactement", "fill"],
              ["Exact — étire aux dimensions exactes", "exact"]
            ],
            { selected: "fit" },
            class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-yellow-400 focus:border-yellow-400 transition-colors outline-none" %>
      </div>

      <%= f.submit "Redimensionner et télécharger",
          class: "w-full px-6 py-3 bg-gray-900 text-white text-sm font-semibold rounded-lg hover:bg-gray-800 active:bg-black transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <div class="mt-5 p-4 bg-gray-50 rounded-xl border border-gray-200">
    <h3 class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2">À propos des modes</h3>
    <ul class="text-xs text-gray-600 space-y-1.5">
      <li><span class="font-medium text-gray-800">Adapter</span> — redimensionne en respectant les proportions, sans dépasser les dimensions indiquées.</li>
      <li><span class="font-medium text-gray-800">Remplir</span> — recadre l'image pour remplir exactement les dimensions demandées.</li>
      <li><span class="font-medium text-gray-800">Exact</span> — redimensionne sans contrainte de proportion (peut déformer l'image).</li>
    </ul>
  </div>

</div>
